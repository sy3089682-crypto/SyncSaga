{
  "name": "@syncsaga/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs,esm --dts --external pino --external cookie-parser --external compression --external pino-http --external pino-pretty --external ws --external stripe --external csrf --external otplib --external qrcode --external jsonwebtoken --external uuid --external rate-limiter-flexible --external livekit-server-sdk --external prom-client --external jsdom --external redis --external socket.io-client",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sentry/node": "^10.56.0",
    "@sentry/profiling-node": "^10.56.0",
    "@supabase/supabase-js": "2.45.0",
    "@syncsaga/config": "*",
    "@syncsaga/types": "*",
    "@types/cors": "2.8.0",
    "@types/express": "4.17.0",
    "@types/morgan": "1.9.0",
    "@upstash/qstash": "2.7.0",
    "@upstash/redis": "1.34.0",
    "bullmq": "^5.0.0",
    "cors": "2.8.5",
    "dotenv": "16.4.0",
    "express": "4.21.0",
    "express-rate-limit": "7.4.0",
    "helmet": "8.0.0",
    "ioredis": "^5.11.1",
    "jose": "5.9.0",
    "morgan": "1.10.0",
    "socket.io": "4.7.0",
    "tsup": "8.3.0",
    "tsx": "4.19.0",
    "typescript": "^5.5.0",
    "zod": "3.23.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "csrf": "^3.1.0",
    "esbuild": "^0.20.0",
    "jsdom": "^24.0.0",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^1.2.7",
    "otplib": "^12.0.1",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "pino-pretty": "^11.0.0",
    "prom-client": "^15.0.0",
    "qrcode": "^1.5.3",
    "rate-limiter-flexible": "^5.0.0",
    "redis": "^4.6.0",
    "socket.io-client": "^4.7.0",
    "stripe": "^17.0.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  }
}
