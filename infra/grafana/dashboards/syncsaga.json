{
  "title": "SyncSaga Overview",
  "panels": [
    {
      "title": "Active Rooms",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [{ "expr": "count(syncsaga_rooms)" }]
    },
    {
      "title": "WebSocket Connections",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(syncsaga_ws_connections)" }]
    },
    {
      "title": "Sync Confidence",
      "type": "gauge",
      "datasource": "Prometheus",
      "targets": [{ "expr": "avg(syncsaga_sync_confidence)" }]
    },
    {
      "title": "API Request Rate",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [{ "expr": "rate(http_requests_total[5m])" }]
    }
  ]
}
