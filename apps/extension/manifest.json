{
  "manifest_version": 3,
  "name": "SyncSaga",
  "version": "1.0.0",
  "description": "Watch videos together in perfect sync. Synchronizes HTML5 video playback across any website.",
  "homepage_url": "https://syncsaga.app",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": ["*://*/*"],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    },
    "default_title": "SyncSaga"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["src/content.ts"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{syncsaga@syncsaga.app}",
      "strict_min_version": "109.0"
    },
    "edge": {
      "browser_action_next_to_addressbar": true
    }
  }
}
