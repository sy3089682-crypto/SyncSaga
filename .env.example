# ─── SyncSaga v2 Environment ───

# Mode
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production-syncsaga-v2-key

# Backend
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_AI_URL=http://localhost:8001
NEXT_PUBLIC_WS_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql://syncsaga:syncsaga@localhost:5432/syncsaga
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_SYNC_CHANNEL=sync:events

# Qdrant Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=anime_fingerprints

# AI Services
OPENCLIP_MODEL=ViT-B-32
WHISPER_MODEL=base
FAISS_INDEX_PATH=./data/indexes/fingerprint.index
FINGERPRINT_DB_PATH=./data/fingerprints

# Celery Workers
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
NUM_WORKERS=4

# LiveKit (Voice)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# AniList API
ANILIST_CLIENT_ID=
ANILIST_CLIENT_SECRET=

# Monitoring
SENTRY_DSN=
PROMETHEUS_PORT=9090
