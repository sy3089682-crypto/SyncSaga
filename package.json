{
  "name": "syncsaga",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.2.4",
  "description": "SyncSaga - Realtime anime watch-party platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write '**/*.{ts,tsx,js,jsx,json,css}'",
    "db:generate": "npm run generate --workspace=packages/db",
    "db:migrate": "npm run migrate --workspace=packages/db",
    "db:studio": "npm run studio --workspace=packages/db",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "vitest": "^1.6.0",
    "prettier": "^3.2.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": ["eslint --fix"],
    "*.{ts,tsx,js,jsx,json,css,md}": ["prettier --write"]
  }
}
